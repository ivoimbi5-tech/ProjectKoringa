{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A project stored in ProjectKoringa",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the project"
        },
        "description": {
          "type": "string",
          "description": "A brief description of the project"
        },
        "link": {
          "type": "string",
          "format": "uri",
          "description": "The URL of the project or site"
        },
        "status": {
          "type": "string",
          "enum": ["ready", "in-progress", "site"],
          "description": "The current status of the project"
        },
        "userId": {
          "type": "string",
          "description": "The UID of the user who owns this project"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the project was created"
        }
      },
      "required": ["name", "status", "userId", "createdAt"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of projects"
    }
  }
}
